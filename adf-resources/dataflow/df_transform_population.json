{
	"name": "df_transform_population",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_raw_population",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ds_lookup_country",
						"type": "DatasetReference"
					},
					"name": "CountryLookup"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "filter1"
				},
				{
					"name": "pivot1"
				},
				{
					"name": "lookup1"
				},
				{
					"name": "MapDrifted1",
					"description": "Creates an explicit mapping for each drifted column"
				},
				{
					"name": "select2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {indic_de,geo\\time} as string,",
				"          {2008 } as string,",
				"          {2009 } as string,",
				"          {2010 } as string,",
				"          {2011 } as string,",
				"          {2012 } as string,",
				"          {2013 } as string,",
				"          {2014 } as string,",
				"          {2015 } as string,",
				"          {2016 } as string,",
				"          {2017 } as string,",
				"          {2018 } as string,",
				"          {2019 } as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          country as string,",
				"          country_code_2_digit as string,",
				"          country_code_3_digit as string,",
				"          continent as string,",
				"          population as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     ignoreNoFilesFound: false) ~> CountryLookup",
				"source1 derive(age_group = split({indic_de,geo\\time},',')[1],",
				"          country_code_2_digit = split({indic_de,geo\\time},',')[2],",
				"          {2019 } = toDecimal(regexReplace({2019 }, '[a-z]', ''), 4, 2)) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          country_code_2_digit,",
				"          age_group,",
				"          {percentage_2019 } = {2019 }",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 filter(!isNull({percentage_2019 })) ~> filter1",
				"filter1 pivot(groupBy(country_code_2_digit),",
				"     pivotBy(age_group),",
				"     age_group = sum({percentage_2019 }),",
				"     columnNaming: '$V$N',",
				"     lateral: true) ~> pivot1",
				"MapDrifted1, CountryLookup lookup(pivot1@country_code_2_digit == CountryLookup@country_code_2_digit,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"pivot1 derive(PC_Y0_14x = toDecimal(byName('PC_Y0_14x')),",
				"          PC_Y15_24x = toDecimal(byName('PC_Y15_24x')),",
				"          PC_Y25_49x = toDecimal(byName('PC_Y25_49x')),",
				"          PC_Y50_64x = toDecimal(byName('PC_Y50_64x')),",
				"          PC_Y65_79x = toDecimal(byName('PC_Y65_79x')),",
				"          PC_Y80_MAXx = toDecimal(byName('PC_Y80_MAXx'))) ~> MapDrifted1",
				"lookup1 select(mapColumn(",
				"          country,",
				"          country_code_2_digit = pivot1@country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          age_group_0_14 = PC_Y0_14x,",
				"          age_group_15_24 = PC_Y15_24x,",
				"          age_group_25_49 = PC_Y25_49x,",
				"          age_group_50_64 = PC_Y50_64x,",
				"          age_group_65_79 = PC_Y65_79x,",
				"          age_group_80_max = PC_Y80_MAXx",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2"
			]
		}
	}
}