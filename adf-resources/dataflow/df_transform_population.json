{
	"name": "df_transform_population",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_raw_population",
						"type": "DatasetReference"
					},
					"name": "PopulationData"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          indic_de as string,",
				"          {geo\\time     2008      2009      2010      2011      2012      2013      2014      2015      2016      2017      2018      2019 } as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     inferDriftedColumnTypes: true,",
				"     ignoreNoFilesFound: false) ~> PopulationData",
				"PopulationData derive() ~> derivedColumn1"
			]
		}
	}
}