{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "covid-reporting-adf9812"
		},
		"ls_ablob_covidreportingsa_properties_typeProperties_serviceEndpoint": {
			"type": "string",
			"defaultValue": "https://covidreportingsa1998.blob.core.windows.net/"
		},
		"ls_adls_covidreportingdl_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://covidreportingdl1998.dfs.core.windows.net/"
		},
		"ls_http_ecdc_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/cloudboxacademy/covid19/refs/heads/main/ecdc_data/"
		},
		"tr_ingest_ecdc_data_properties_pl_ingest_ecdc_data_parameters_source_relative_url": {
			"type": "string",
			"defaultValue": "hospital_admissions.csv"
		},
		"tr_ingest_ecdc_data_properties_pl_ingest_ecdc_data_parameters_sink_file_name": {
			"type": "string",
			"defaultValue": "hospital_admissions.csv"
		},
		"tr_ingest_population_data_blob_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/4b3f9a5b-93de-4658-ab32-468834b6023f/resourceGroups/covid-reporting-rg/providers/Microsoft.Storage/storageAccounts/covidreportingsa1998"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "covid-reporting-adf9812_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_ablob_covidreportingsa_properties_typeProperties_serviceEndpoint": {
						"value": "[parameters('ls_ablob_covidreportingsa_properties_typeProperties_serviceEndpoint')]"
					},
					"ls_adls_covidreportingdl_properties_typeProperties_url": {
						"value": "[parameters('ls_adls_covidreportingdl_properties_typeProperties_url')]"
					},
					"ls_http_ecdc_properties_typeProperties_url": {
						"value": "[parameters('ls_http_ecdc_properties_typeProperties_url')]"
					},
					"tr_ingest_ecdc_data_properties_pl_ingest_ecdc_data_parameters_source_relative_url": {
						"value": "[parameters('tr_ingest_ecdc_data_properties_pl_ingest_ecdc_data_parameters_source_relative_url')]"
					},
					"tr_ingest_ecdc_data_properties_pl_ingest_ecdc_data_parameters_sink_file_name": {
						"value": "[parameters('tr_ingest_ecdc_data_properties_pl_ingest_ecdc_data_parameters_sink_file_name')]"
					},
					"tr_ingest_population_data_blob_properties_typeProperties_scope": {
						"value": "[parameters('tr_ingest_population_data_blob_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}